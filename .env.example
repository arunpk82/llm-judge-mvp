# =======================================================================
# LLM-Judge Platform — Environment Configuration
# =======================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Docker-compose reads .env automatically.
# For non-Docker use, export these variables or leave unset for defaults.
# =======================================================================

# -----------------------------------------------------------------------
# Judge Engine Selection
# -----------------------------------------------------------------------
# Which scoring engine to use. Options:
#   deterministic  — Gate 1 only: regex + BM25 rules (default, no API key needed)
#   gemini         — Gate 2: Google Gemini + deterministic fallback
#   groq           — Gate 2: Groq + deterministic fallback
#   openai         — Gate 2: OpenAI + deterministic fallback
#   ollama         — Gate 2: Ollama (local) + deterministic fallback
#   sequential     — Gate 1 first, escalate low-confidence to Gate 2
JUDGE_ENGINE=deterministic

# For sequential mode: which LLM provider for Gate 2
# GATE2_ENGINE=gemini

# -----------------------------------------------------------------------
# LLM Provider API Keys (required when JUDGE_ENGINE != deterministic)
# -----------------------------------------------------------------------
# Google Gemini (free tier available)
# GEMINI_API_KEY=

# OpenAI
# LLM_API_KEY=

# Groq (free tier available)
# GROQ_API_KEY=

# Ollama (local — no key needed, just set the base URL)
# OLLAMA_BASE_URL=http://localhost:11434

# LLM request timeout in milliseconds (default: 15000)
# JUDGE_TIMEOUT_MS=15000

# -----------------------------------------------------------------------
# Path Configuration (EPIC-D1)
# -----------------------------------------------------------------------
# Root directory for configuration files (read-only at runtime).
# Docker default: /app/configs. Local default: configs (relative to CWD).
# LLM_JUDGE_CONFIGS_DIR=/app/configs

# Root directory for all persistent data (reports, baselines, datasets).
# Docker default: /data (mounted volume). Local default: . (project root).
# Sub-directories are auto-resolved:
#   reports/    — evaluation reports, audit logs, drift analysis
#   baselines/  — baseline snapshots for regression detection
#   datasets/   — registered datasets and generated test cases
# LLM_JUDGE_DATA_DIR=/data

# -----------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------
# Port mapping for docker-compose (host:container)
LLM_JUDGE_PORT=8000
